# ===== Evolution API (WhatsApp Web) =====
EVOLUTION_BASE_URL=http://evolution-api:8080
EVOLUTION_APIKEY=change-me-strong-api-key
EVOLUTION_INSTANCE=1etiket-main

# Bot Webhook (Evolution API buraya event atacak)
EVOLUTION_WEBHOOK_PATH=/webhook/evolution
WEBHOOK_PUBLIC_URL=https://bot.1etiket.com.tr/webhook/evolution

# ===== Admin Panel =====
ADMIN_SECRET=change-me-admin-secret-key

# ===== PostgreSQL (Evolution API için) =====
POSTGRES_PASSWORD=change-me-strong-db-password

# ===== WooCommerce REST API =====
WC_URL=https://1etiket.com.tr
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxx
WC_WEBHOOK_SECRET=your_wc_webhook_secret

# ===== Fiyat Hesaplama API =====
PRICE_API_URL=https://1etiket.com.tr/wp-json/1etiket/v1/calculate-price
PRICE_API_KEY=your_internal_api_key

# ===== Sunucu =====
PORT=3000
NODE_ENV=production

# ===== Veritabanı (bot konuşmaları — SQLite) =====
DB_PATH=./data/conversations.db

# ===== Dosya Depolama =====
UPLOAD_DIR=./uploads/baski-dosyalari
MAX_FILE_SIZE=25000000
